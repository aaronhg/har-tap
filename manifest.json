{
  "manifest_version": 3,
  "name": "HAR Tap (dev)",
  "version": "0.1.0",
  "description": "Capture a tab's network into a standard HAR via chrome.debugger (CDP Network), including cross-origin (OOPIF) iframes. Load unpacked; a developer tool.",
  "permissions": ["debugger", "tabs", "storage", "unlimitedStorage"],
  "background": { "service_worker": "background.js", "type": "module" },
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HAR Tap",
    "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png" }
  }
}
